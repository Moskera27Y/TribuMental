# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# WOMPI_PUBLIC_KEY: Required for real payment processing with Wompi Checkout.
# Obtain this from your Wompi Dashboard (Integrations -> Public Key).
WOMPI_PUBLIC_KEY=

# WOMPI_PRIVATE_KEY: Required for verifying Wompi transaction statuses.
# Obtain this from your Wompi Dashboard (Integrations -> Private Key).
WOMPI_PRIVATE_KEY=

# WOMPI_INTEGRITY_KEY: Required for generating the integrity signature.
# Obtain this from your Wompi Dashboard (Integrations -> Integrity Secret).
WOMPI_INTEGRITY_KEY=

# GOOGLE_CLIENT_ID: Your Google Cloud Console OAuth 2.0 Web Client ID.
# Obtain this from the GCP credentials tab (API & Services -> Credentials).
GOOGLE_CLIENT_ID=

# GOOGLE_CLIENT_SECRET: Your Google Cloud Console OAuth 2.0 Client Secret.
GOOGLE_CLIENT_SECRET=
